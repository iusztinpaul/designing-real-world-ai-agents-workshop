# Mandatory
GOOGLE_API_KEY=...

# Optional
OPIK_API_KEY=... # For observability and evals
OPIK_WORKSPACE=... # Opik workspace name (optional, uses default workspace if unset)
OPIK_PROJECT_NAME=... # Opik project name (defaults: research-agent / writing-workflow)
LOG_LEVEL=20 # Python logging level (10=DEBUG, 20=INFO, 30=WARNING)
